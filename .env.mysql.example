# Configuration MySQL pour Laragon
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=waraniene_db

# Configuration Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PayDunya (Paiements)
PAYDUNYA_MASTER_KEY=your_paydunya_master_key
PAYDUNYA_PRIVATE_KEY=your_paydunya_private_key
PAYDUNYA_PUBLIC_KEY=your_paydunya_public_key
PAYDUNYA_TOKEN=your_paydunya_token

# KKiaPay (Paiements alternatifs)
NEXT_PUBLIC_KKIAPAY_PUBLIC_KEY=your_kkiapay_public_key
NEXT_PUBLIC_KKIAPAY_PRIVATE_KEY=your_kkiapay_private_key

# JWT Secret pour l'authentification
JWT_SECRET=votre_secret_jwt_tres_securise_changez_moi
JWT_EXPIRES_IN=7d

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre_email@gmail.com
EMAIL_PASSWORD=votre_mot_de_passe_app
EMAIL_FROM=noreply@waraniene.com

# SMS (pour OTP)
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=Waraniene

# Upload Storage (local ou cloud)
UPLOAD_DIR=public/uploads
MAX_FILE_SIZE=5242880

# Mode de développement
NODE_ENV=development
